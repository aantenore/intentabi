{
  "name": "@intentabi/adapter-codex-sdk",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Source-only, contract-tested adapter from the official Codex SDK Thread.run API to IntentABI.",
  "author": "Antonio Antenore <ant_ant95@hotmail.it> (https://github.com/aantenore)",
  "homepage": "https://github.com/aantenore/intentabi#readme",
  "bugs": {
    "url": "https://github.com/aantenore/intentabi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aantenore/intentabi.git",
    "directory": "packages/adapter-codex-sdk"
  },
  "keywords": [
    "agentic-ai",
    "codex",
    "codex-sdk",
    "context-engineering",
    "shadow-runtime",
    "typescript"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.contract.json"
  },
  "dependencies": {
    "@intentabi/codex-host": "workspace:*"
  },
  "devDependencies": {
    "@openai/codex-sdk": "0.144.4"
  }
}
