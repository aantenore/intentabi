{
  "name": "@intentabi/adapter-semwitness",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Source-only SemWitness qualification adapter for IntentABI.",
  "author": "Antonio Antenore <ant_ant95@hotmail.it> (https://github.com/aantenore)",
  "homepage": "https://github.com/aantenore/intentabi#readme",
  "bugs": {
    "url": "https://github.com/aantenore/intentabi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aantenore/intentabi.git",
    "directory": "packages/adapter-semwitness"
  },
  "keywords": [
    "agentic-ai",
    "intent-normalization",
    "semantic-cache",
    "semwitness",
    "typescript"
