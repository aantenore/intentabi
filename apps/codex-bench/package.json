{
  "name": "@intentabi/codex-bench",
  "version": "0.2.0-alpha.2",
  "private": true,
  "description": "Opt-in, research-only Codex SDK paired benchmark runner for IntentABI.",
  "author": "Antonio Antenore <ant_ant95@hotmail.it> (https://github.com/aantenore)",
  "homepage": "https://github.com/aantenore/intentabi#readme",
  "bugs": {
    "url": "https://github.com/aantenore/intentabi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aantenore/intentabi.git",
    "directory": "apps/codex-bench"
  },
  "keywords": [
    "benchmark",
    "codex",
    "conformance",
    "llm-evaluation"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "intentabi-codex-bench": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@intentabi/adapter-codex-sdk": "workspace:*",
    "@intentabi/benchmark-core": "workspace:*",
    "@intentabi/cli-io": "workspace:*",
    "@intentabi/core": "workspace:*",
    "@openai/codex-sdk": "0.144.4",
    "zod": "4.4.3"
  }
}
